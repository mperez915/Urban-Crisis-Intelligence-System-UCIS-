# UCIS Environment Configuration

# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_PORT_AMQP_HOST=5672       # Puerto AMQP expuesto al host
RABBITMQ_PORT_MGMT_HOST=15672      # Puerto Management UI expuesto al host
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=admin123

# MongoDB Configuration
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_PORT_HOST=27017              # Puerto MongoDB expuesto al host
MONGO_USERNAME=admin
MONGO_PASSWORD=admin123

# Simulator Configuration
EVENT_RATE=100                     # eventos por segundo
LOG_LEVEL=INFO

# Flask API Configuration
FLASK_ENV=development
FLASK_DEBUG=False
API_PORT_INTERNAL=5000             # Puerto interno del contenedor API
API_PORT_HOST=5001                 # Puerto expuesto al host (cambiar si 5000 está ocupado)

# CEP Engine Configuration
CEP_PORT_HOST=8081                 # Puerto CEP Engine expuesto al host

# Enricher Configuration
ENRICHER_PORT_HOST=8082            # Puerto Enricher expuesto al host

# WebSocket Server Configuration
WEBSOCKET_PORT_INTERNAL=8083       # Puerto interno del contenedor WebSocket
WEBSOCKET_PORT_HOST=8083           # Puerto WebSocket expuesto al host

# Frontend Configuration
FRONTEND_PORT_HOST=3000            # Puerto frontend expuesto al host

# General Configuration
ENVIRONMENT=development
